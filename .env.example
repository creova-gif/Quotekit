# QuoteKit — Environment Variables Template
# Copy this file to .env or .env.local and fill in the values

# ─── Supabase Configuration ───────────────────────────────────────────────────
# Find these in your Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Stripe Configuration (Canada / Global Payments) ────────────────────────
# Find these in your Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs for Subscription Tiers
# Create these products/prices in your Stripe Dashboard.
# Note: Card funding Radar rule should be configured in Stripe to block prepaid cards.
VITE_STRIPE_PRICE_PRO_CAD=price_...
VITE_STRIPE_PRICE_PRO_USD=price_...
VITE_STRIPE_PRICE_BUSINESS_CAD=price_...
VITE_STRIPE_PRICE_BUSINESS_USD=price_...

# ─── Resend Configuration (Email Sending) ────────────────────────────────────
# Find this in your Resend Dashboard → API Keys (used by Edge functions / backend)
RESEND_API_KEY=re_...

# ─── AI Configuration (QuickPropose) ─────────────────────────────────────────
# Google Gemini API key for AI-driven proposal generation
GEMINI_API_KEY=AIzaSy...
